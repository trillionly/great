    function buildChartData(snapData, totalUsd, totalInvested) {
        const dNow = new Date();
        const chartData = snapData || [];
        const todayStr = `${dNow.getFullYear()}. ${dNow.getMonth()+1}. ${dNow.getDate()}`;
        const needsInsert = totalUsd > 0 && !chartData.find(r => r.record_date === todayStr);

        if (needsInsert) {
            chartData.push({ record_date: todayStr, total_asset: totalUsd, principal: totalInvested });
        }

        chartData.sort((a, b) => new Date(a.record_date.replace(/\.\s/g, '-')) - new Date(b.record_date.replace(/\.\s/g, '-')));
        return { chartData, todayStr, needsInsert };
    }

    function calculateTotalHistoricalReturns(chartData, totalUsd) {
        const dNow = new Date();
        const oneMonthAgo = new Date(dNow.getFullYear(), dNow.getMonth() - 1, dNow.getDate());
        const oneYearAgo = new Date(dNow.getFullYear() - 1, dNow.getMonth(), dNow.getDate());

        function getPastAsset(targetDate) {
            let closest = null, minDiff = Infinity;
            for (const row of chartData) {
                const rowDate = new Date(row.record_date.replace(/\.\s/g, '-'));
                const diff = Math.abs(targetDate - rowDate);
                if (diff < 15 * 24 * 60 * 60 * 1000 && diff < minDiff) {
                    minDiff = diff;
                    closest = row.total_asset;
                }
            }
            return closest;
        }

        const asset1Mo = getPastAsset(oneMonthAgo);
        const asset1Yr = getPastAsset(oneYearAgo);
        return {

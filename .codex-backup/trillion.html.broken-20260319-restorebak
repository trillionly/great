    async function fetchHistoryFromFinnhub(symbol) {
        const nowSec = Math.floor(Date.now() / 1000);
        const from = nowSec - (370 * 86400);
        const to = nowSec;
        const data = await fetchJsonWithTimeout(`https://finnhub.io/api/v1/stock/candle?symbol=${symbol}&resolution=D&from=${from}&to=${to}&token=${FINNHUB_API_KEY}`);

        if (data.s !== 'ok' || !Array.isArray(data.t) || !Array.isArray(data.c) || data.t.length === 0) {
            throw new Error('Finnhub candle unavailable');
        }

        return {
            timestamps: data.t,
            closes: data.c,
            source: 'Finnhub'
        };
    }

    async function fetchHistoryFromYahoo(symbol, proxyName) {
        const targetUrl = `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1y`;
        const proxyUrl = proxyName === 'corsproxy'
            ? `https://corsproxy.io/?${encodeURIComponent(targetUrl)}`
            : `https://api.allorigins.win/raw?url=${encodeURIComponent(targetUrl)}`;
        const data = await fetchJsonWithTimeout(proxyUrl);
        const result = data?.chart?.result?.[0];
        const timestamps = result?.timestamp;
        const closes = result?.indicators?.quote?.[0]?.close;

        if (!Array.isArray(timestamps) || !Array.isArray(closes) || timestamps.length === 0) {
            throw new Error(`Yahoo ${proxyName} unavailable`);
        }

        return {
            timestamps,
            closes,
            source: proxyName === 'corsproxy' ? 'Yahoo/corsproxy' : 'Yahoo/allorigins'
        };
    }

    async function fetchAllHistoryPrice(symbol) {
        const nowSec = Math.floor(Date.now() / 1000);
        const targetMo = nowSec - (30 * 86400);
        const targetYr = nowSec - (365 * 86400);
        const providers = [
            () => fetchHistoryFromFinnhub(symbol),
            () => fetchHistoryFromYahoo(symbol, 'corsproxy'),
            () => fetchHistoryFromYahoo(symbol, 'allorigins')
        ];

        for (const provider of providers) {
            try {
                const result = await provider();
                const mo = findClosestClose(result.timestamps, result.closes, targetMo);
                const yr = findClosestClose(result.timestamps, result.closes, targetYr);

                if (Number.isFinite(mo) && Number.isFinite(yr)) {
                    const payload = { mo, yr, source: result.source };
                    savePriceCache(symbol, payload);
                    return payload;
                }
            } catch (e) {
                console.warn(`${symbol} 湲곗?媛 議고쉶 ?ㅽ뙣`, e);
            }
        }

        const cached = loadPriceCache(symbol);
        if (cached) {
            return { mo: cached.mo, yr: cached.yr, source: `Cache/${cached.source || 'unknown'}` };
        }

        return { mo: null, yr: null, source: 'None' };
    }

